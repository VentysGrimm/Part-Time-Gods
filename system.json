      "system": "part-time-gods"
    },
    {
      "name": "maps",
      "label": "Part-Time Gods Maps",
      "path": "packs/maps",
      "type": "Scene",
      "system": "part-time-gods"
    },
    {
      "name": "rules-reference",
      "label": "Part-Time Gods Rules Reference",
      "path": "packs/rules-reference",
      "type": "JournalEntry",
      "system": "part-time-gods"
    }
  ],

  "documentTypes": {
    "Actor": {
