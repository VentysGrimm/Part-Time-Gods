        "htmlFields": ["benefit", "description", "notes"]
      },
      "vassal": {
        "htmlFields": ["benefit", "description", "notes"]
      },
      "blessing": {
        "htmlFields": ["effect", "notes"]
      },
      "curse": {
        "htmlFields": ["effect", "notes"]
      },
      "weapon": {
        "htmlFields": ["description", "notes"]
      },
      "armor": {
        "htmlFields": ["description", "notes"]
      }
