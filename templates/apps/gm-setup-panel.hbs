<section class="ptg-gm-setup-panel">
  <header class="ptg-gm-setup-header">
    <div>
      <h1>{{title}}</h1>
      <p>{{firstRunHint}}</p>
      <span>{{userRole}}</span>
    </div>
    {{#unless isGM}}
      <strong>{{gmActionsDisabled}}</strong>
    {{/unless}}
  </header>

  <section class="ptg-gm-setup-groups">
    {{#each groups as |group|}}
      <section class="ptg-gm-setup-group">
        <header>
          <h2>{{group.label}}</h2>
        </header>
        <p>{{group.hint}}</p>
        <div class="ptg-gm-setup-actions">
          {{#each group.actions as |action|}}
            <button type="button" data-setup-action="{{action.key}}" title="{{action.hint}}" aria-label="{{action.label}}: {{action.hint}}" {{#if action.disabled}}disabled{{/if}}>
              <i class="{{action.icon}}"></i>
              <span>
                <strong>{{action.label}}</strong>
                <small>{{action.hint}}</small>
              </span>
              {{#if action.gmOnly}}<em>{{@root.gmBadge}}</em>{{/if}}
            </button>
          {{/each}}
        </div>
      </section>
    {{/each}}
  </section>
</section>
