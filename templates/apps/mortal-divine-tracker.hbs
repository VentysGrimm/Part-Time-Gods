<section class="ptg-balance-tracker">
  {{#if actor}}
    <header class="ptg-balance-actor">
      <img src="{{actor.img}}" alt="{{actor.name}}">
      <div>
        <h2>{{actor.name}}</h2>
        <p>{{actor.label}} ({{actor.value}})</p>
      </div>
    </header>

    <section class="ptg-balance-meter" aria-label="Mortal-Divine Balance meter">
      <div class="ptg-balance-scale">
        <span>Mortal</span>
        <strong>Balanced</strong>
        <span>Divine</span>
      </div>
      <div class="ptg-balance-bar">
        <i style="left: {{actor.percent}}%;"></i>
      </div>
      <div class="ptg-balance-values">
        <span>{{min}}</span>
        <span>0</span>
        <span>+{{max}}</span>
      </div>
    </section>

    <section class="ptg-balance-actions">
      <div>
        <h3>Mortal Pressure</h3>
        {{#each mortalButtons as |button|}}
          <button type="button" data-balance-action data-balance-direction="mortal" data-balance-amount="{{button.amount}}" data-balance-reason="{{button.label}}">
            {{button.label}}
          </button>
        {{/each}}
      </div>
      <div>
        <h3>Divine Pressure</h3>
        {{#each divineButtons as |button|}}
          <button type="button" data-balance-action data-balance-direction="divine" data-balance-amount="{{button.amount}}" data-balance-reason="{{button.label}}">
            {{button.label}}
          </button>
        {{/each}}
      </div>
    </section>

    <section class="ptg-balance-custom">
      <h3>Custom Adjustment</h3>
      <div class="ptg-item-fields three">
        <label>
          <span>Direction</span>
          <select name="balanceDirection">
            <option value="mortal">Mortal</option>
            <option value="divine">Divine</option>
          </select>
        </label>
        <label>
          <span>Amount</span>
          <input name="balanceAmount" type="number" value="1" min="1" max="10">
        </label>
        <button type="button" data-balance-custom>Apply</button>
      </div>
      <label>
        <span>GM Note</span>
        <textarea name="balanceNote" placeholder="What changed the balance?"></textarea>
      </label>
    </section>

    <section class="ptg-balance-log">
      <header>
        <h3>Recent Movement</h3>
        <button type="button" data-balance-clear>Clear Log</button>
      </header>
      {{#if log.length}}
        <ol>
          {{#each log as |entry|}}
            <li>
              <strong>{{entry.direction}} {{entry.amount}}</strong>
              <span>{{entry.reason}}</span>
              <small>{{entry.before}} -> {{entry.after}}</small>
              {{#if entry.note}}<p>{{entry.note}}</p>{{/if}}
            </li>
          {{/each}}
        </ol>
      {{else}}
        <p class="ptg-sheet-note">No Mortal-Divine Balance events logged yet.</p>
      {{/if}}
    </section>
  {{else}}
    <section class="ptg-balance-empty">
      <h2>Mortal-Divine Balance</h2>
      <p>Drop a character actor here to begin tracking.</p>
    </section>
  {{/if}}
</section>
