      <label><span>Manifestations</span><textarea readonly>{{json system.grants.manifestations}}</textarea></label>
      <label><span>Resources</span><textarea readonly>{{json system.grants.resources}}</textarea></label>
      <label><span>Attachments</span><textarea readonly>{{json system.grants.attachments}}</textarea></label>
      <label><span>Blessing</span><input name="system.grants.blessing" type="text" value="{{system.grants.blessing}}"></label>
      <label><span>Curse</span><input name="system.grants.curse" type="text" value="{{system.grants.curse}}"></label>
    </section>

    <details class="ptg-editor-section" open>
      <summary><span>Description</span></summary>
      {{editor system.description target="system.description" button=true editable=editable engine="prosemirror"}}
    </details>
    <details class="ptg-editor-section" open>
      <summary><span>Limitations</span></summary>
      {{editor system.limitations target="system.limitations" button=true editable=editable engine="prosemirror"}}
