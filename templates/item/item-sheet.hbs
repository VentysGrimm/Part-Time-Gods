<form class="ptg-sheet ptg-item-sheet" autocomplete="off">
  <header class="ptg-header">
    <img class="profile-img" src="{{itemImg}}" data-fallback-src="{{itemImageFallback}}" data-edit="img" title="{{item.name}}" alt="{{item.name}}">
    <div class="ptg-title">
      <input class="ptg-name" name="name" type="text" value="{{item.name}}" placeholder="{{itemTypeLabel}} Name">
      <div class="ptg-subtitle">{{itemTypeLabel}}</div>
    </div>
  </header>

  {{#if (eq item.type "occupation")}}
    <section class="ptg-item-fields two">
      <label>
        <span>Category</span>
        <input name="system.category" type="text" value="{{system.category}}">
      </label>
      <label>
        <span>Career</span>
        <input name="system.career" type="text" value="{{system.career}}">
      </label>
    </section>
    <section class="ptg-grants">
      <label><span>Skills</span><textarea readonly>{{json system.grants.skills}}</textarea></label>
      <label><span>Manifestations</span><textarea readonly>{{json system.grants.manifestations}}</textarea></label>
      <label><span>Resources</span><textarea readonly>{{json system.grants.resources}}</textarea></label>
      <label><span>Attachments</span><textarea readonly>{{json system.grants.attachments}}</textarea></label>
      <label><span>Blessing</span><input name="system.grants.blessing" type="text" value="{{system.grants.blessing}}"></label>
      <label><span>Curse</span><input name="system.grants.curse" type="text" value="{{system.grants.curse}}"></label>
      <label class="span-2"><span>Career Options</span><textarea readonly>{{json system.careerOptions}}</textarea></label>
    </section>
    <details class="ptg-editor-section" open>
      <summary><span>Description</span></summary>
      {{editor system.description target="system.description" button=true editable=editable engine="prosemirror"}}
    </details>
    <details class="ptg-editor-section" open>
      <summary><span>Notes</span></summary>
      {{editor system.notes target="system.notes" button=true editable=editable engine="prosemirror"}}
    </details>
  {{/if}}

  {{#if (eq item.type "archetype")}}
    <section class="ptg-item-fields two">
      <label class="span-2">
        <span>Defining Trait</span>
        <input name="system.definingTrait" type="text" value="{{system.definingTrait}}">
      </label>
    </section>
    <section class="ptg-grants">
      <label><span>Skills</span><textarea readonly>{{json system.grants.skills}}</textarea></label>
      <label><span>Manifestations</span><textarea readonly>{{json system.grants.manifestations}}</textarea></label>
      <label><span>Resources</span><textarea readonly>{{json system.grants.resources}}</textarea></label>
      <label><span>Attachments</span><textarea readonly>{{json system.grants.attachments}}</textarea></label>
      <label><span>Blessing</span><input name="system.grants.blessing" type="text" value="{{system.grants.blessing}}"></label>
      <label><span>Curse</span><input name="system.grants.curse" type="text" value="{{system.grants.curse}}"></label>
    </section>
    <details class="ptg-editor-section" open>
      <summary><span>Description</span></summary>
      {{editor system.description target="system.description" button=true editable=editable engine="prosemirror"}}
    </details>
    <details class="ptg-editor-section" open>
      <summary><span>Notes</span></summary>
      {{editor system.notes target="system.notes" button=true editable=editable engine="prosemirror"}}
    </details>
  {{/if}}

  {{#if (eq item.type "domain")}}
    <section class="ptg-item-fields three">
      <label>
        <span>Category</span>
        <select name="system.category">
          {{#each config.domainCategories as |label key|}}
            <option value="{{key}}" {{#if (eq ../system.category key)}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </label>
      <label>
        <span>Rank</span>
        <input name="system.rank" type="number" value="{{system.rank}}" min="0">
      </label>
      <label>
        <span>Manifestations</span>
        <input name="system.manifestations" type="text" value="{{system.manifestations}}" placeholder="Aegis +1, Soul +1">
      </label>
      <label>
        <span>Portfolio</span>
        <textarea class="ptg-long-field" name="system.portfolio" rows="2" placeholder="War, Love, Storms">{{system.portfolio}}</textarea>
      </label>
      <label>
        <span>Custom Title</span>
        <textarea class="ptg-long-field" name="system.customTitle" rows="2" placeholder="God of Storms">{{system.customTitle}}</textarea>
      </label>
      <label>
        <span>Scope</span>
        <select name="system.specificity">
          <option value="specific" {{#if (eq system.specificity "specific")}}selected{{/if}}>Specific</option>
          <option value="broad" {{#if (eq system.specificity "broad")}}selected{{/if}}>Broad</option>
        </select>
      </label>
      <label class="span-2">
        <span>Specific Portfolio</span>
        <textarea class="ptg-long-field" name="system.specificPortfolio" rows="2">{{system.specificPortfolio}}</textarea>
      </label>
      <label>
        <span>Landmark Bond</span>
