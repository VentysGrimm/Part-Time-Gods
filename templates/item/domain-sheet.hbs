<form class="part-time-gods sheet item domain-sheet {{cssClass}}" autocomplete="off">

    {{!-- HEADER --}}
    <header class="ptg-header sheet-header">

        <img
            class="profile-img"
            src="{{item.img}}"
            data-fallback-src="icons/svg/item-bag.svg"
            data-edit="img"
            title="{{item.name}}"
            alt="{{item.name}}"
            height="96"
            width="96"
        />

        <div class="ptg-title header-fields">

            <input
                class="ptg-name"
                name="name"
                type="text"
                value="{{item.name}}"
                placeholder="Domain Name"
            />
            <div class="ptg-subtitle">Domain</div>

            <div class="ptg-item-fields three stats grid grid-3col">

                <div class="resource">
                    <label>Rank</label>
                    <input
                        type="number"
                        name="system.rank"
                        value="{{item.system.rank}}"
                        min="0"
                    />
                </div>

                <div class="resource">
                    <label>Influence</label>
                    <input
                        type="number"
                        name="system.influence"
                        value="{{item.system.influence}}"
                        min="0"
                    />
                </div>

                <div class="resource">
                    <label>Worshippers</label>
                    <input
                        type="number"
                        name="system.worshippers"
                        value="{{item.system.worshippers}}"
                        min="0"
                    />
                </div>

            </div>

        </div>

    </header>

    {{!-- NAVIGATION TABS --}}
    <nav class="ptg-tabs sheet-tabs tabs" data-group="primary">
        <a class="item active" data-tab="details">Details</a>
        <a class="item" data-tab="powers">Powers</a>
        <a class="item" data-tab="notes">Notes</a>
    </nav>

    {{!-- BODY --}}
    <section class="sheet-body">

        {{!-- DETAILS TAB --}}
        <div class="tab details active" data-group="primary" data-tab="details">

            <div class="form-group">
                <label>Portfolio</label>
                <input
                    type="text"
                    name="system.portfolio"
                    value="{{item.system.portfolio}}"
                    placeholder="War, Love, Storms, Knowledge..."
                />
            </div>

            <div class="form-group">
                <label>Sphere of Influence</label>
                <input
                    type="text"
                    name="system.sphere"
                    value="{{item.system.sphere}}"
                />
            </div>

            <div class="form-group stacked">
                <label>Description</label>
                {{editor
                    item.system.description
                    target="system.description"
                    button=true
                    editable=editable
                }}
            </div>

        </div>

        {{!-- POWERS TAB --}}
        <div class="tab powers" data-group="primary" data-tab="powers">

            <div class="form-group stacked">
                <label>Miracles</label>
                {{editor
                    item.system.miracles
                    target="system.miracles"
                    button=true
                    editable=editable
                }}
            </div>

            <div class="form-group stacked">
                <label>Blessings</label>
                {{editor
                    item.system.blessings
                    target="system.blessings"
                    button=true
                    editable=editable
                }}
            </div>

            <div class="form-group stacked">
                <label>Curses</label>
                {{editor
                    item.system.curses
                    target="system.curses"
                    button=true
                    editable=editable
                }}
            </div>

        </div>

        {{!-- NOTES TAB --}}
        <div class="tab notes" data-group="primary" data-tab="notes">

            <div class="form-group stacked">
                <label>GM Notes</label>
                {{editor
                    item.system.notes
                    target="system.notes"
                    button=true
                    editable=editable
                }}
            </div>

        </div>

    </section>

</form>
