<form class="part-time-gods sheet item ptg-power-sheet {{cssClass}}" autocomplete="off">

  {{!-- ================= HEADER ================= --}}
  <header class="ptg-header sheet-header">

    <img
      class="profile-img"
      src="{{itemImg}}"
      data-fallback-src="{{itemImageFallback}}"
      data-edit="img"
      title="{{item.name}}"
      alt="{{item.name}}"
      width="100"
      height="100"
    />

    <div class="ptg-title header-fields">

      <input
        class="ptg-name item-name"
        name="name"
        type="text"
        value="{{item.name}}"
        placeholder="Power Name"
      />
      <div class="ptg-subtitle">Power</div>

      <div class="ptg-item-fields three grid grid-3col">

        <div class="field">
          <label>Domain</label>
          <input
            type="text"
            name="system.domain"
            value="{{system.domain}}"
            placeholder="e.g. War, Love, Death"
          />
        </div>

        <div class="field">
          <label>Rank</label>
          <input
            type="number"
            name="system.rank"
            value="{{system.rank}}"
            min="0"
            step="1"
          />
        </div>

        <div class="field">
          <label>Cost</label>
          <input
            type="number"
            name="system.cost"
            value="{{system.cost}}"
            min="0"
            step="1"
          />
        </div>

      </div>
    </div>

  </header>

  {{!-- ================= TABS ================= --}}
  <nav class="ptg-tabs sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="description">Description</a>
    <a class="item" data-tab="mechanics">Mechanics</a>
    <a class="item" data-tab="advanced">Advanced</a>
  </nav>

  <section class="sheet-body">

    {{!-- =============== DESCRIPTION TAB =============== --}}
    <div class="tab" data-group="primary" data-tab="description">

      <div class="form-group stacked">
        <label>Description</label>
        {{editor system.description
          target="system.description"
          button=true
          editable=editable
        }}
      </div>

    </div>

    {{!-- =============== MECHANICS TAB =============== --}}
    <div class="tab" data-group="primary" data-tab="mechanics">

      <div class="grid grid-2col">

        <div class="field">
          <label>Activation</label>
          <select name="system.activation">
            {{selectOptions system.config.activationTypes selected=system.activation}}
          </select>
        </div>

        <div class="field">
          <label>Duration</label>
          <input
            type="text"
            name="system.duration"
            value="{{system.duration}}"
            placeholder="Instant, Scene, Sustained..."
          />
        </div>

        <div class="field">
          <label>Range</label>
          <input
            type="text"
            name="system.range"
            value="{{system.range}}"
            placeholder="Self, Touch, Sight..."
          />
        </div>

        <div class="field">
          <label>Target</label>
          <input
            type="text"
            name="system.target"
            value="{{system.target}}"
            placeholder="Creature, Area, Object..."
          />
        </div>

      </div>

      <div class="form-group stacked">
        <label>Effect</label>
        {{editor system.effect
          target="system.effect"
          button=true
          editable=editable
        }}
      </div>

      <div class="form-group stacked">
        <label>Limitations</label>
        {{editor system.limitations
          target="system.limitations"
          button=true
          editable=editable
        }}
      </div>

    </div>

    {{!-- =============== ADVANCED TAB =============== --}}
    <div class="tab" data-group="primary" data-tab="advanced">

      <div class="grid grid-2col">

        <label class="checkbox">
          <input
            type="checkbox"
            name="system.requiresRoll"
            {{checked system.requiresRoll}}
          />
          Requires Roll
        </label>

        <div class="field">
          <label>Difficulty</label>
          <input
            type="number"
            name="system.difficulty"
            value="{{system.difficulty}}"
            min="0"
            step="1"
          />
        </div>

        <label class="checkbox">
          <input
            type="checkbox"
            name="system.passive"
            {{checked system.passive}}
          />
          Passive Power
        </label>

        <label class="checkbox">
          <input
            type="checkbox"
            name="system.visible"
            {{checked system.visible}}
          />
          Visible Effect
        </label>

      </div>

      <div class="form-group stacked">
        <label>GM Notes</label>
        {{editor system.notes
          target="system.notes"
          button=true
          editable=editable
        }}
      </div>

    </div>

  </section>
</form>
