<form class="ptg-sheet ptg-compact-sheet" autocomplete="off">
  <header class="ptg-header">
    <img class="profile-img" src="{{actorImg}}" data-fallback-src="{{imageFallback}}" data-edit="img" title="{{actor.name}}" alt="{{actor.name}}">
    <div class="ptg-title">
      <input class="ptg-name" name="name" type="text" value="{{actor.name}}" placeholder="Antagonist Name">
      <div class="ptg-subtitle">Antagonist{{#if system.rank}} - {{system.rank}}{{/if}}</div>
    </div>
    {{#if canUseSetupTools}}
      <button type="button" data-antagonist-builder>Opposition Builder</button>
    {{/if}}
  </header>

  <section class="ptg-item-fields three">
    <label>
      <span>Type</span>
      <input name="system.antagonistType" type="text" value="{{system.antagonistType}}" placeholder="Outsider, Mortal, Spirit">
    </label>
    <label>
      <span>Rank</span>
      <input name="system.rank" type="text" value="{{system.rank}}" placeholder="Warrior, Master, Grand Master">
    </label>
    <label>
      <span>Source Page</span>
      <input name="system.sourcePage" type="number" value="{{system.sourcePage}}" min="0">
    </label>
  </section>

  <section class="ptg-stat-grid">
    <label>
      <span>Threat</span>
      <input name="system.threat" type="number" value="{{system.threat}}" min="1">
    </label>
    <label>
      <span>Threshold</span>
      <input name="system.threshold" type="number" value="{{system.threshold}}" min="0">
    </label>
    <label>
      <span>Health</span>
      <input name="system.health" type="number" value="{{system.health}}" min="0">
    </label>
    <label>
      <span>Psyche</span>
      <input name="system.psyche" type="number" value="{{system.psyche}}" min="0">
    </label>
    <label>
      <span>Armor</span>
      <input name="system.armor" type="number" value="{{system.armor}}" min="0">
    </label>
    <label>
      <span>Spark</span>
      <input name="system.spark" type="number" value="{{system.spark}}" min="0">
    </label>
    <label>
      <span>Fragments</span>
      <input name="system.fragments" type="number" value="{{system.fragments}}" min="0">
    </label>
    <label>
      <span>Attack</span>
      <input name="system.attack" type="number" value="{{system.attack}}" min="0">
    </label>
    <label>
      <span>Defense</span>
      <input name="system.defense" type="number" value="{{system.defense}}" min="0">
    </label>
    <label>
      <span>Initiative</span>
      <input name="system.initiative" type="number" value="{{system.initiative}}">
    </label>
    <label>
      <span>Damage</span>
      <input name="system.damage" type="number" value="{{system.damage}}" min="0">
    </label>
  </section>

  <section class="ptg-item-fields">
    <label>
      <span>Skills</span>
      <input name="system.skills" type="text" value="{{system.skills}}" placeholder="Athletics, Fighting, Fortitude">
    </label>
    <label>
      <span>Conditions</span>
      <textarea name="system.conditionHandling" rows="3" placeholder="Antagonist condition handling">{{system.conditionHandling}}</textarea>
    </label>
  </section>

  <section class="ptg-panel-section ptg-antagonist-combat-panel">
    <h2>Combat Actions</h2>
    <div class="ptg-action-row">
      <button type="button" data-antagonist-combat-roll="attack">Roll Attack</button>
      <button type="button" data-antagonist-combat-roll="defense">Roll Defense</button>
      {{#if canUseCombatControls}}
        <button type="button" data-antagonist-combat-controls>Combat Controls</button>
      {{/if}}
    </div>
    <p class="ptg-sheet-note">Attack and Defense roll the listed statblock pool as d10 successes. Use Combat Controls for action markers, Battle resolution, Health/Psyche damage, armor, and Conditions.</p>
  </section>

  <section class="ptg-editor-section">
    <h2>Description</h2>
    {{editor system.description target="system.description" button=true editable=editable engine="prosemirror"}}
  </section>

  <section class="ptg-editor-section">
    <h2>Powers</h2>
    {{editor system.powers target="system.powers" button=true editable=editable engine="prosemirror"}}
  </section>

  <section class="ptg-editor-section">
    <h2>Notes</h2>
    {{editor system.notes target="system.notes" button=true editable=editable engine="prosemirror"}}
  </section>
</form>
