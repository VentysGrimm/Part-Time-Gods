<form class="ptg-sheet ptg-character-sheet" autocomplete="off">
  <nav class="ptg-page-tabs tabs" data-group="primary" aria-label="Character sheet pages">
    <button type="button" class="item active" data-group="primary" data-tab="front" data-ptg-tab="front">Page 1</button>
    <button type="button" class="item" data-group="primary" data-tab="back" data-ptg-tab="back">Page 2</button>
  </nav>

  <section class="ptg-character-page tab active" data-group="primary" data-tab="front" data-ptg-panel="front">
    <header class="ptg-paper-header">
      <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}">
      <div class="ptg-paper-title">
        <label class="ptg-line-field wide">
          <span>Name</span>
          <input class="ptg-name" name="name" type="text" value="{{actor.name}}">
        </label>
        <label class="ptg-line-field wide">
          <span>God/dess Of</span>
          <input name="system.identity.concept" type="text" value="{{system.identity.concept}}">
        </label>
      </div>
    </header>

    <section class="ptg-paper-panel ptg-creation-panel">
      <div class="ptg-panel-heading">
        <h2>Character Creation</h2>
        <button type="button" data-character-creator>Creator</button>
      </div>
      <ol class="ptg-creation-steps">
        {{#each creationSteps as |step|}}
          <li class="ptg-creation-step{{#if step.complete}} complete{{/if}}">
            <span class="ptg-step-number">{{step.number}}</span>
            <div class="ptg-step-main">
              <strong>{{step.title}}</strong>
              <span>{{step.detail}}</span>
            </div>
            <small>{{step.source}}</small>
          </li>
        {{/each}}
      </ol>
    </section>

    <div class="ptg-page-one-grid">
      <section class="ptg-paper-panel ptg-conditions-panel">
        <label>
          <span>Conditions</span>
          <textarea name="system.conditions">{{system.conditions}}</textarea>
        </label>
        <div class="ptg-mini-item-list">
          {{#each inventory.conditions as |item|}}
            <div class="ptg-mini-item" data-item-id="{{item.id}}">
              <span>{{item.name}}</span>
              <small>{{item.system.category}} {{item.system.severity}}</small>
              <button type="button" data-item-action="condition-reduce">Reduce</button>
              <button type="button" data-item-action="edit">Edit</button>
              <button type="button" data-item-action="delete">Remove</button>
              {{#if item.sheetDetails}}
                <div class="ptg-item-details">
                  {{#each item.sheetDetails as |detail|}}
                    <div><strong>{{detail.label}}</strong> {{{detail.html}}}</div>
                  {{/each}}
                </div>
              {{/if}}
            </div>
          {{/each}}
        </div>
        <label>
          <span>Failings</span>
          <textarea name="system.attachments.failings">{{system.attachments.failings}}</textarea>
        </label>
      </section>

      <section class="ptg-paper-panel ptg-derived-panel">
        <div class="ptg-readout"><span>Initiative</span><strong>{{system.derived.initiative}}</strong></div>
        <div class="ptg-readout"><span>Strength</span><strong>{{system.derived.strength}}</strong></div>
        <div class="ptg-readout"><span>Movement</span><strong>{{system.derived.movement}}</strong></div>
        <label class="ptg-line-field">
          <span>Work FT/W</span>
          <input name="system.resources.occupationFreeTime" type="number" value="{{system.resources.occupationFreeTime}}" min="0">
        </label>
        <label class="ptg-line-field">
          <span>Spark</span>
          <input name="system.resources.spark" type="number" value="{{system.resources.spark}}" min="1">
        </label>
      </section>

      <section class="ptg-paper-panel ptg-resource-panel">
        <label class="ptg-track">
          <span>Health</span>
          <input name="system.resources.health.value" type="number" value="{{system.resources.health.value}}" min="0">
          <strong>Max {{system.resources.health.max}}</strong>
          <em>5 + Fortitude</em>
        </label>
        <label class="ptg-track">
          <span>Psyche</span>
          <input name="system.resources.psyche.value" type="number" value="{{system.resources.psyche.value}}" min="0">
          <strong>Max {{system.resources.psyche.max}}</strong>
          <em>5 + Discipline</em>
        </label>
        <label class="ptg-track">
          <span>Free Time</span>
          <input name="system.resources.freeTime" type="number" value="{{system.resources.freeTime}}" min="0">
          <input name="system.resources.freeTimeMax" type="number" value="{{system.resources.freeTimeMax}}" min="0" aria-label="Free Time Max">
          <em>Max</em>
        </label>
        <label class="ptg-track">
          <span>Wealth</span>
          <input name="system.resources.wealth" type="number" value="{{system.resources.wealth}}" min="0">
          <input name="system.resources.wealthMax" type="number" value="{{system.resources.wealthMax}}" min="0" aria-label="Wealth Max">
          <em>Max</em>
        </label>
        <label class="ptg-track">
          <span>Fragments</span>
          <input name="system.resources.fragments.value" type="number" value="{{system.resources.fragments.value}}" min="0">
          <strong>Max {{system.resources.fragments.max}}</strong>
          <em>Spark x3</em>
        </label>
        <label>
          <span>Legendary Acts</span>
          <textarea name="system.resources.legendaryActs">{{system.resources.legendaryActs}}</textarea>
        </label>
      </section>
    </div>

    <section class="ptg-paper-panel ptg-identity-strip">
      <label class="ptg-line-field">
        <span>Occupation</span>
        <input name="system.identity.occupation" type="text" value="{{system.identity.occupation}}">
      </label>
      <label class="ptg-line-field">
        <span>Archetype</span>
        <input name="system.identity.archetype" type="text" value="{{system.identity.archetype}}">
      </label>
      <label class="ptg-line-field">
        <span>Age & Ethnicity</span>
        <input name="system.identity.ageEthnicity" type="text" value="{{system.identity.ageEthnicity}}">
      </label>
      <label class="ptg-line-field">
        <span>Theology</span>
        <input name="system.identity.theology" type="text" value="{{system.identity.theology}}">
      </label>
      <label class="ptg-line-field">
        <span>Dominion</span>
        <input name="system.identity.dominion" type="text" value="{{system.identity.dominion}}">
      </label>
    </section>

    <section class="ptg-paper-panel ptg-dominion-strip">
      <label class="ptg-line-field">
        <span>Dominion Title</span>
        <input name="system.identity.dominionTitle" type="text" value="{{system.identity.dominionTitle}}" placeholder="God of Storms">
      </label>
      <label class="ptg-line-field">
        <span>Specific Portfolio</span>
        <input name="system.identity.dominionPortfolio" type="text" value="{{system.identity.dominionPortfolio}}">
      </label>
      <label class="ptg-line-field">
        <span>Scope</span>
        <select name="system.identity.dominionSpecificity">
          <option value="specific" {{#if (eq system.identity.dominionSpecificity "specific")}}selected{{/if}}>Specific</option>
          <option value="broad" {{#if (eq system.identity.dominionSpecificity "broad")}}selected{{/if}}>Broad</option>
        </select>
      </label>
      <label class="ptg-line-field">
        <span>Landmark Bond</span>
        <input name="system.identity.dominionLandmarkBondName" type="text" value="{{system.identity.dominionLandmarkBondName}}" readonly>
      </label>
      <label class="ptg-line-field span-4">
        <span>Dominion Limits</span>
        <textarea name="system.identity.dominionLimitations">{{system.identity.dominionLimitations}}</textarea>
      </label>
    </section>

    <section class="ptg-paper-columns">
      <section class="ptg-paper-panel">
        <h2>Skills</h2>
        <div class="ptg-skill-columns">
          {{#each skillColumns as |column|}}
            <div class="ptg-score-column">
              {{#each column as |key|}}
                <label class="ptg-score-row">
                  <button type="button" data-roll-skill="{{key}}">{{ptgLabel "skills" key}}</button>
                  <input name="system.skills.{{key}}" type="number" value="{{lookup @root.system.skills key}}" min="0">
                </label>
              {{/each}}
            </div>
          {{/each}}
        </div>
        <p class="ptg-sheet-note">Make Skill + Skill combo and roll dice equal to their total value. 7-9 = 1 Success, 10 = 2 successes.</p>
      </section>

      <section class="ptg-paper-panel">
        <h2>Manifestations</h2>
        <div class="ptg-manifestation-columns">
          {{#each manifestationColumns as |column|}}
            <div class="ptg-score-column">
              {{#each column as |key|}}
                <label class="ptg-score-row">
                  <button type="button" data-roll-manifestation="{{key}}">{{ptgLabel "manifestations" key}}</button>
                  <input name="system.manifestations.{{key}}" type="number" value="{{lookup @root.system.manifestations key}}" min="0">
                </label>
              {{/each}}
            </div>
          {{/each}}
        </div>
        <p class="ptg-sheet-note">Manifestation + Skill: 7-9 = 1 Success, 10 = 2 successes. Level 0 Manifestations cannot be used.</p>
        <div class="ptg-roll-controls ptg-paper-rolls">
          <label>
            <span>Second Skill</span>
            <select data-roll-secondary>
              {{#each skills as |label key|}}
                <option value="{{key}}">{{label}}</option>
              {{/each}}
            </select>
          </label>
          <label>
            <span>Manifest Skill</span>
            <select data-roll-manifestation-skill>
              {{#each skills as |label key|}}
                <option value="{{key}}" {{#if (eq key "discipline")}}selected{{/if}}>{{label}}</option>
              {{/each}}
            </select>
          </label>
          <label>
            <span>Difficulty</span>
            <select data-roll-difficulty>
              {{#each difficulties as |value key|}}
                <option value="{{value}}">{{ptgLabel "difficulties" key}} ({{value}})</option>
              {{/each}}
            </select>
          </label>
        </div>
        <div class="ptg-roll-controls ptg-ritual-controls">
          <button type="button" data-ritual-action="territory">Territory Ritual</button>
          <button type="button" data-ritual-action="spark">Spark Ritual</button>
          <button type="button" data-ritual-action="otherworldly">Otherworldly Ritual</button>
        </div>
      </section>
    </section>

    <section class="ptg-paper-panel">
      <label>
        <span>Specialties</span>
        <textarea name="system.specialties">{{system.specialties}}</textarea>
      </label>
      <div class="ptg-xp-row">
        <label class="ptg-line-field">
          <span>XP Gained</span>
          <input name="system.resources.xpGained" type="number" value="{{system.resources.xpGained}}" min="0">
        </label>
        <label class="ptg-line-field">
          <span>XP Spent</span>
          <input name="system.resources.xpSpent" type="number" value="{{system.resources.xpSpent}}" min="0">
        </label>
        <div class="ptg-readout">
          <span>Unspent XP</span>
          <strong>{{xpUnspent}}</strong>
        </div>
        <button type="button" data-xp-award>Award XP</button>
        <button type="button" data-advancement-purchase>Spend XP</button>
        <button type="button" data-spark-advancement>Advance Spark</button>
      </div>
    </section>
  </section>

  <section class="ptg-character-page tab" data-group="primary" data-tab="back" data-ptg-panel="back" hidden>
    <section class="ptg-back-top">
      <div class="ptg-paper-panel">
        <h2>Blessings</h2>
        <p class="ptg-sheet-note">Bonuses or special abilities.</p>
        <textarea name="system.attachments.blessings">{{system.attachments.blessings}}</textarea>
        <div class="ptg-mini-item-list">
          {{#each inventory.blessings as |item|}}
            <div class="ptg-mini-item" data-item-id="{{item.id}}">
              <span>{{item.name}}</span>
              <button type="button" data-item-action="edit">Edit</button>
              {{#if item.sheetDetails}}
                <div class="ptg-item-details">
                  {{#each item.sheetDetails as |detail|}}
                    <div><strong>{{detail.label}}</strong> {{{detail.html}}}</div>
                  {{/each}}
                </div>
              {{/if}}
            </div>
          {{/each}}
        </div>
      </div>

      <div class="ptg-paper-panel">
        <h2>Curses</h2>
        <p class="ptg-sheet-note">Penalties or negative traits that produce Pantheon Dice.</p>
        <textarea name="system.attachments.curses">{{system.attachments.curses}}</textarea>
        <div class="ptg-mini-item-list">
          {{#each inventory.curses as |item|}}
            <div class="ptg-mini-item" data-item-id="{{item.id}}">
              <span>{{item.name}}</span>
              <button type="button" data-item-action="edit">Edit</button>
              {{#if item.sheetDetails}}
                <div class="ptg-item-details">
                  {{#each item.sheetDetails as |detail|}}
                    <div><strong>{{detail.label}}</strong> {{{detail.html}}}</div>
                  {{/each}}
                </div>
              {{/if}}
            </div>
          {{/each}}
        </div>
      </div>
    </section>

    <section class="ptg-paper-panel">
      <h2>Bonds</h2>
      <textarea name="system.attachments.bonds">{{system.attachments.bonds}}</textarea>
      <table class="ptg-paper-table">
        <thead>
          <tr><th>Name</th><th>Type</th><th>Location</th><th>Level</th><th>Strain</th><th></th></tr>
        </thead>
        <tbody>
          {{#each inventory.bonds as |item|}}
            <tr data-item-id="{{item.id}}">
              <td>{{item.name}}</td>
              <td>{{item.system.kind}}</td>
              <td>{{item.system.location}}</td>
              <td>{{item.system.level}}</td>
              <td>{{item.system.strain.value}} / {{item.system.strain.max}}</td>
              <td><button type="button" data-item-action="edit">Edit</button></td>
            </tr>
            {{#if item.sheetDetails}}
              <tr class="ptg-item-detail-row">
                <td colspan="6">
                  <div class="ptg-item-details">
                    {{#each item.sheetDetails as |detail|}}
                      <div><strong>{{detail.label}}</strong> {{{detail.html}}}</div>
                    {{/each}}
                  </div>
                </td>
              </tr>
            {{/if}}
          {{/each}}
        </tbody>
      </table>
    </section>

    <section class="ptg-paper-panel">
      <h2>Worshippers / Vassals</h2>
      <div class="ptg-back-text-pair">
        <textarea name="system.attachments.worshippers">{{system.attachments.worshippers}}</textarea>
        <textarea name="system.attachments.vassals">{{system.attachments.vassals}}</textarea>
      </div>
      <table class="ptg-paper-table">
        <thead>
          <tr><th>Name</th><th>Type</th><th>Location</th><th>Level</th><th>Strain</th><th></th></tr>
        </thead>
        <tbody>
          {{#each inventory.worshippers as |item|}}
            <tr data-item-id="{{item.id}}">
              <td>{{item.name}}</td>
              <td>Worshipper</td>
              <td>{{item.system.group}}</td>
              <td>{{item.system.level}}</td>
              <td>{{item.system.strain.value}}</td>
              <td>
                <button type="button" data-item-action="use">Use</button>
                <button type="button" data-item-action="edit">Edit</button>
              </td>
            </tr>
            {{#if item.sheetDetails}}
              <tr class="ptg-item-detail-row">
                <td colspan="6">
                  <div class="ptg-item-details">
                    {{#each item.sheetDetails as |detail|}}
                      <div><strong>{{detail.label}}</strong> {{{detail.html}}}</div>
                    {{/each}}
                  </div>
                </td>
              </tr>
            {{/if}}
          {{/each}}
          {{#each inventory.vassals as |item|}}
            <tr data-item-id="{{item.id}}">
              <td>{{item.name}}</td>
              <td>Vassal</td>
              <td>{{item.system.concept}}</td>
              <td>{{item.system.level}}</td>
              <td>{{item.system.loyalty}}</td>
              <td>
                <button type="button" data-item-action="use">Use</button>
                <button type="button" data-item-action="edit">Edit</button>
              </td>
            </tr>
            {{#if item.sheetDetails}}
              <tr class="ptg-item-detail-row">
                <td colspan="6">
                  <div class="ptg-item-details">
                    {{#each item.sheetDetails as |detail|}}
                      <div><strong>{{detail.label}}</strong> {{{detail.html}}}</div>
                    {{/each}}
                  </div>
                </td>
              </tr>
            {{/if}}
          {{/each}}
        </tbody>
      </table>
    </section>

    <section class="ptg-back-bottom">
      <div class="ptg-paper-panel">
        <h2>Relics</h2>
        <textarea name="system.attachments.relics">{{system.attachments.relics}}</textarea>
        <div class="ptg-mini-item-list">
          {{#each inventory.relics as |item|}}
            <div class="ptg-mini-item" data-item-id="{{item.id}}">
              <span>{{item.name}}</span>
              <span>Level {{item.system.level}}</span>
              <button type="button" data-item-action="use">Use</button>
              <button type="button" data-item-action="edit">Edit</button>
              {{#if item.sheetDetails}}
                <div class="ptg-item-details">
                  {{#each item.sheetDetails as |detail|}}
                    <div><strong>{{detail.label}}</strong> {{{detail.html}}}</div>
                  {{/each}}
                </div>
              {{/if}}
            </div>
          {{/each}}
        </div>
      </div>

      <div class="ptg-paper-panel">
        <h2>Truths</h2>
        <textarea name="system.attachments.truths">{{system.attachments.truths}}</textarea>
        <div class="ptg-mini-item-list">
          {{#each inventory.truths as |item|}}
            <div class="ptg-mini-item" data-item-id="{{item.id}}">
              <span>{{item.name}}</span>
              <span>Rank {{item.system.rank}}</span>
              <button type="button" data-item-action="use">Use</button>
              <button type="button" data-item-action="edit">Edit</button>
              {{#if item.sheetDetails}}
                <div class="ptg-item-details">
                  {{#each item.sheetDetails as |detail|}}
                    <div><strong>{{detail.label}}</strong> {{{detail.html}}}</div>
                  {{/each}}
                </div>
              {{/if}}
            </div>
          {{/each}}
        </div>
      </div>
    </section>

    <section class="ptg-paper-panel">
      <h2>Gear and Notes</h2>
      <div class="ptg-inventory-summary">
        <span>Total Cost {{gearSummary.cost}}</span>
        <span>Total Wt {{gearSummary.weight}}</span>
        <span>Equipped Armor {{gearSummary.equippedArmor}}</span>
      </div>
      {{> "systems/part-time-gods/templates/actor/parts/item-list.hbs" items=inventory.gear mode="gear"}}
      <div class="ptg-editor-section">
        {{editor system.notes target="system.notes" button=true editable=editable engine="prosemirror"}}
      </div>
    </section>
  </section>
</form>
