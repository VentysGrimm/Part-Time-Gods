<form class="ptg-sheet ptg-character-sheet" autocomplete="off">
  <nav class="ptg-page-tabs tabs" data-group="primary" aria-label="{{ptgLocalize "PTG.Sheet.CharacterPages"}}">
    <button type="button" class="item active" data-group="primary" data-tab="front" data-ptg-tab="front" title="{{ptgLocalize "PTG.Sheet.PrintedPage1"}}">{{ptgLocalize "PTG.Sheet.Page1"}}</button>
    <button type="button" class="item" data-group="primary" data-tab="back" data-ptg-tab="back" title="{{ptgLocalize "PTG.Sheet.PrintedPage2"}}">{{ptgLocalize "PTG.Sheet.Page2"}}</button>
  </nav>

  <section class="ptg-print-tools" aria-label="{{ptgLocalize "PTG.Sheet.FoundryCharacterTools"}}">
    <button type="button" data-character-creator title="{{ptgLocalize "PTG.Help.CharacterCreator"}}">{{ptgLocalize "PTG.Sheet.Creator"}}</button>
    <button type="button" data-mortality-workflow title="{{ptgLocalize "PTG.Help.MortalDivineBalance"}}">{{ptgLocalize "PTG.Sheet.Mortality"}}: {{system.mortality.state}}</button>
    <button type="button" data-resource-workflow="work" title="{{ptgLocalize "PTG.Help.FreeTime"}}">{{ptgLocalize "PTG.Sheet.GoToWork"}}</button>
    {{#each pantheonMembership as |pantheon|}}
      <button type="button" data-pantheon-pool-workflow data-pantheon-uuid="{{pantheon.uuid}}" title="{{ptgLocalize "PTG.Help.PantheonPool"}}">{{pantheon.name}} {{ptgLocalize "PTG.Sheet.Pool"}} {{pantheon.pool}}</button>
    {{/each}}
  </section>

  <section class="ptg-character-page ptg-print-page ptg-print-front tab active" data-group="primary" data-tab="front" data-ptg-panel="front">
    <header class="ptg-print-header">
      <div class="ptg-print-logo" aria-label="Part-Time Gods Second Edition">
        <strong>Part-Time<br>Gods</strong>
        <span>Second Edition</span>
      </div>
      <div class="ptg-print-title-fields">
        <label class="ptg-print-title-field">
          <span>Name:</span>
          <input class="ptg-name" name="name" type="text" value="{{actor.name}}">
        </label>
        <label class="ptg-print-title-field">
          <span>God/dess Of:</span>
          <input name="system.identity.concept" type="text" value="{{system.identity.concept}}">
        </label>
      </div>
    </header>

    <section class="ptg-print-front-grid">
      <section class="ptg-print-section ptg-print-lines ptg-print-conditions">
        <div class="ptg-print-section-heading">
          <h2 title="{{ptgLocalize "PTG.Help.Conditions"}}">Conditions</h2>
          {{#if editable}}<button type="button" data-condition-create title="{{ptgLocalize "PTG.Help.Conditions"}}">Add</button>{{/if}}
        </div>
        {{#if system.derived.conditionWarnings}}
          <ul class="ptg-print-warning-list">
            {{#each system.derived.conditionWarnings as |condition|}}
              <li><strong>{{condition.name}}</strong> {{condition.severity}}{{#if condition.summary}} - {{condition.summary}}{{/if}}</li>
            {{/each}}
          </ul>
        {{/if}}
        <textarea name="system.conditions" aria-label="Condition notes" title="{{ptgLocalize "PTG.Help.Conditions"}}">{{system.conditions}}</textarea>
        {{#if inventory.conditions.length}}
          <div class="ptg-print-condition-list">
            {{#each inventory.conditions as |item|}}
              <article class="ptg-print-condition" data-item-id="{{item.id}}">
                <strong>{{item.name}}</strong>
                <span>Level {{item.system.severity}}</span>
                <div>
                  <button type="button" data-item-action="condition-reduce" aria-label="Reduce {{item.name}} severity">-</button>
                  <button type="button" data-item-action="condition-increase" aria-label="Increase {{item.name}} severity">+</button>
                  <button type="button" data-item-action="condition-recover">Recover</button>
                  <button type="button" data-item-action="edit">Edit</button>
                  <button type="button" data-item-action="delete">Remove</button>
                </div>
              </article>
            {{/each}}
          </div>
        {{/if}}
      </section>

      <section class="ptg-print-stat-stack" aria-label="Derived stats">
        <div class="ptg-print-stat">
          <h2>Initiative</h2>
          <strong>{{system.derived.initiative}}</strong>
        </div>
        <div class="ptg-print-stat">
          <h2>Strength</h2>
          <strong>{{system.derived.strength}}</strong>
        </div>
        <div class="ptg-print-stat">
          <h2>Movement</h2>
          <strong>{{system.derived.movement}}</strong>
        </div>
        <label class="ptg-print-stat editable">
          <h2>Work FT/W</h2>
          <input name="system.resources.occupationFreeTime" type="number" value="{{system.resources.occupationFreeTime}}" min="0">
        </label>
        <label class="ptg-print-stat editable">
          <h2 title="{{ptgLocalize "PTG.Help.Spark"}}">Spark</h2>
          <input name="system.resources.spark" type="number" value="{{system.resources.spark}}" min="1" title="{{ptgLocalize "PTG.Help.Spark"}}">
        </label>
      </section>

      <section class="ptg-print-resource-panel" aria-label="Character resources">
        {{#each frontResourceTracks as |track|}}
          <div class="ptg-print-resource {{track.key}}">
            <header>
              <h2 title="{{track.help}}">{{track.label}}</h2>
              <span>Max</span>
              <strong>{{track.max}}</strong>
              <em>{{track.formula}}</em>
            </header>
            <div class="ptg-resource-pips" role="group" aria-label="{{track.label}} {{track.value}} of {{track.max}}" title="{{track.help}}">
              <button type="button" data-resource-step="{{track.key}}" data-resource-delta="-1" aria-label="Decrease {{track.label}}">-</button>
              <div class="ptg-resource-boxes">
                {{#each track.boxes as |box|}}
                  <button
                    type="button"
                    class="ptg-resource-box{{#if box.filled}} filled{{/if}}"
                    data-resource-box="{{track.key}}"
                    data-resource-value="{{box.value}}"
                    aria-label="{{box.label}}"
                    title="{{box.label}}"
                  ></button>
                {{/each}}
              </div>
              <button type="button" data-resource-step="{{track.key}}" data-resource-delta="1" aria-label="Increase {{track.label}}">+</button>
            </div>
          </div>
        {{/each}}

        {{#each downtimeResourceTracks as |track|}}
          <div class="ptg-print-resource ptg-print-flat-resource {{track.key}}">
            <header>
              <h2 title="{{track.help}}">{{track.label}}</h2>
              <span>Max</span>
              <input name="{{track.maxName}}" type="number" value="{{track.max}}" min="0" aria-label="{{track.label}} Max" title="{{track.help}}">
            </header>
            <div class="ptg-resource-pips" role="group" aria-label="{{track.label}} {{track.value}} of {{track.max}}" title="{{track.help}}">
              <button type="button" data-flat-resource-step="{{track.key}}" data-resource-delta="-1" aria-label="Decrease {{track.label}}">-</button>
              <div class="ptg-resource-boxes">
                {{#each track.boxes as |box|}}
                  <button
                    type="button"
                    class="ptg-resource-box{{#if box.filled}} filled{{/if}}"
                    data-flat-resource-box="{{track.key}}"
                    data-resource-value="{{box.value}}"
                    aria-label="{{box.label}}"
                    title="{{box.label}}"
                  ></button>
                {{/each}}
              </div>
              <button type="button" data-flat-resource-step="{{track.key}}" data-resource-delta="1" aria-label="Increase {{track.label}}">+</button>
              <button type="button" class="ptg-print-manage-resource" data-resource-workflow="{{track.workflow}}" aria-label="Manage {{track.label}}" title="{{track.help}}">Manage</button>
            </div>
          </div>
        {{/each}}

        <div class="ptg-print-resource legendary">
          <header><h2>Legendary Acts</h2></header>
          <textarea name="system.resources.legendaryActs">{{system.resources.legendaryActs}}</textarea>
        </div>

        {{#with fragmentResourceTrack as |track|}}
          <div class="ptg-print-resource {{track.key}}">
            <header>
              <h2 title="{{track.help}}">{{track.label}}</h2>
              <span>Max</span>
              <strong>{{track.max}}</strong>
              <em>{{track.formula}}</em>
            </header>
            <div class="ptg-resource-pips" role="group" aria-label="{{track.label}} {{track.value}} of {{track.max}}" title="{{track.help}}">
              <button type="button" data-resource-step="{{track.key}}" data-resource-delta="-1" aria-label="Decrease {{track.label}}">-</button>
              <div class="ptg-resource-boxes">
                {{#each track.boxes as |box|}}
                  <button
                    type="button"
                    class="ptg-resource-box{{#if box.filled}} filled{{/if}}"
                    data-resource-box="{{track.key}}"
                    data-resource-value="{{box.value}}"
                    aria-label="{{box.label}}"
                    title="{{box.label}}"
                  ></button>
                {{/each}}
              </div>
              <button type="button" data-resource-step="{{track.key}}" data-resource-delta="1" aria-label="Increase {{track.label}}">+</button>
            </div>
          </div>
        {{/with}}
      </section>

      <section class="ptg-print-section ptg-print-lines ptg-print-failings">
        <div class="ptg-print-section-heading">
          <h2>Failings</h2>
        </div>
        <textarea name="system.attachments.failings" aria-label="Failings">{{system.attachments.failings}}</textarea>
      </section>
    </section>

    <section class="ptg-print-identity">
      <label>
        <span>Occupation:</span>
        <input name="system.identity.occupation" type="text" value="{{system.identity.occupation}}">
      </label>
      <label>
        <span>Age & Ethnicity:</span>
        <input name="system.identity.ageEthnicity" type="text" value="{{system.identity.ageEthnicity}}">
      </label>
      <label>
        <span>Theology:</span>
        <input name="system.identity.theology" type="text" value="{{system.identity.theology}}">
      </label>
      <label>
        <span>Archetype:</span>
        <input name="system.identity.archetype" type="text" value="{{system.identity.archetype}}">
      </label>
      <label>
        <span>Dominion:</span>
        <input name="system.identity.dominion" type="text" value="{{system.identity.dominion}}">
      </label>
    </section>

    <section class="ptg-print-score-grid">
      <section class="ptg-print-section ptg-print-skills">
        <h2>Skills</h2>
        <div class="ptg-skill-columns">
          {{#each skillColumns as |column|}}
            <div class="ptg-score-column">
              {{#each column as |key|}}
                <label class="ptg-score-row">
                  <button type="button" data-roll-skill="{{key}}">{{ptgLabel "skills" key}}</button>
                  <input name="system.skills.{{key}}" type="number" value="{{lookup @root.system.skills key}}" min="0">
                </label>
              {{/each}}
            </div>
          {{/each}}
        </div>
        <p class="ptg-print-help">Make Skill + Skill combo and roll dice equal to their total value. <strong>7-9</strong> = 1 Success, <strong>10</strong> = 2 successes.</p>
      </section>

      <section class="ptg-print-side-stack">
        <section class="ptg-print-section ptg-print-manifestations">
          <h2 title="{{ptgLocalize "PTG.Help.ManifestationMeasures"}}">Manifestations</h2>
          <div class="ptg-manifestation-columns">
            {{#each manifestationColumns as |column|}}
              <div class="ptg-score-column">
                {{#each column as |key|}}
                  <label class="ptg-score-row">
                    <button type="button" data-roll-manifestation="{{key}}" title="{{ptgLocalize "PTG.Help.ManifestationMeasures"}}">{{ptgLabel "manifestations" key}}</button>
                    <input name="system.manifestations.{{key}}" type="number" value="{{lookup @root.system.manifestations key}}" min="0">
                  </label>
                {{/each}}
              </div>
            {{/each}}
          </div>
          <p class="ptg-print-help" title="{{ptgLocalize "PTG.Help.ManifestationMeasures"}}">Manifestation + Skill. <strong>7-9</strong> = 1 Success, <strong>10</strong> = 2 successes. Level 0 Manifestations cannot be used. {{ptgLocalize "PTG.Help.ManifestationMeasures"}}</p>
          <div class="ptg-print-mini-actions">
            <button type="button" data-ritual-action="territory">Territory Ritual</button>
            <button type="button" data-ritual-action="spark">Spark Ritual</button>
            <button type="button" data-ritual-action="otherworldly">Otherworldly Ritual</button>
          </div>
        </section>

        <section class="ptg-print-xp">
          <label>
            <span>XP Gained</span>
            <input name="system.resources.xpGained" type="number" value="{{system.resources.xpGained}}" min="0">
          </label>
          <label>
            <span>XP Spent</span>
            <input type="number" value="{{xpSpent}}" min="0" readonly aria-readonly="true">
          </label>
          <strong>Unspent {{xpUnspent}}</strong>
          <button type="button" data-xp-award>Award</button>
          <button type="button" data-advancement-purchase>Spend</button>
          <button type="button" data-spark-advancement title="{{ptgLocalize "PTG.Help.Spark"}}">Spark</button>
        </section>
      </section>
    </section>

    <section class="ptg-print-section ptg-print-specialties">
      <label>
        <span>Specialties</span>
        <textarea name="system.specialties">{{system.specialties}}</textarea>
      </label>
    </section>
  </section>

  <section class="ptg-character-page ptg-print-page ptg-print-back tab" data-group="primary" data-tab="back" data-ptg-panel="back" hidden>
    <section class="ptg-print-back-top">
      <section class="ptg-print-section">
        <div class="ptg-print-section-heading">
          <h2>Blessings</h2>
          {{#if editable}}<button type="button" data-item-create="blessing">Add</button>{{/if}}
        </div>
        <p class="ptg-print-caption">Bonuses or special abilities.</p>
        <div class="ptg-print-ability-list">
          {{#each inventory.blessings as |item|}}
            <article class="ptg-print-ability" data-item-id="{{item.id}}">
              <header>
                <strong>{{item.name}}</strong>
                {{#if item.hasDetails}}
                  <button type="button" data-item-action="toggle-details" aria-expanded="{{item.expanded}}">{{#if item.expanded}}Hide{{else}}Details{{/if}}</button>
                {{/if}}
                <button type="button" data-item-action="edit">Edit</button>
              </header>
              {{#if item.hasDetails}}
                {{#if item.expanded}}
                  <div class="ptg-item-details">
                    {{#each item.sheetDetails as |detail|}}
                      <div><strong>{{detail.label}}</strong> {{{detail.html}}}</div>
                    {{/each}}
                  </div>
                {{/if}}
              {{/if}}
            </article>
          {{/each}}
        </div>
      </section>

      <section class="ptg-print-section">
        <div class="ptg-print-section-heading">
          <h2>Curses</h2>
          {{#if editable}}<button type="button" data-item-create="curse">Add</button>{{/if}}
        </div>
        <p class="ptg-print-caption">Penalties or negative traits that produce Pantheon Dice.</p>
        <div class="ptg-print-ability-list">
          {{#each inventory.curses as |item|}}
            <article class="ptg-print-ability" data-item-id="{{item.id}}">
              <header>
                <strong>{{item.name}}</strong>
                {{#if item.hasDetails}}
                  <button type="button" data-item-action="toggle-details" aria-expanded="{{item.expanded}}">{{#if item.expanded}}Hide{{else}}Details{{/if}}</button>
                {{/if}}
                <button type="button" data-item-action="edit">Edit</button>
              </header>
              {{#if item.hasDetails}}
                {{#if item.expanded}}
                  <div class="ptg-item-details">
                    {{#each item.sheetDetails as |detail|}}
                      <div><strong>{{detail.label}}</strong> {{{detail.html}}}</div>
                    {{/each}}
                  </div>
                {{/if}}
              {{/if}}
            </article>
          {{/each}}
        </div>
      </section>
    </section>

    <section class="ptg-print-section" data-item-drop-type="bond">
      <div class="ptg-print-section-heading">
        <h2>Bonds</h2>
        {{#if editable}}<button type="button" data-item-create="bond">Add</button>{{/if}}
      </div>
      <div class="ptg-print-attachment-table bonds">
        <div class="ptg-print-attachment-head" title="{{ptgLocalize "PTG.Help.Strain"}}">
          <span>Name</span>
          <span>Type</span>
          <span>Location</span>
          <span>Level</span>
          <span>Strain</span>
          <span></span>
        </div>
        {{#each inventory.bonds as |item|}}
          <article class="ptg-print-attachment-row" data-item-id="{{item.id}}">
            <span class="ptg-print-attachment-name">
              {{#if item.hasDetails}}
                <button type="button" class="ptg-detail-toggle" data-item-action="toggle-details" aria-expanded="{{item.expanded}}">{{#if item.expanded}}Hide{{else}}Show{{/if}}</button>
              {{else}}
                <span class="ptg-detail-toggle-placeholder" aria-hidden="true"></span>
              {{/if}}
              <strong>{{item.name}}</strong>
            </span>
            <span>{{item.system.kind}}</span>
            <span>{{item.system.location}}</span>
            <span class="ptg-print-box">{{item.system.level}}</span>
            <span class="ptg-print-box">{{item.system.strain.value}} / {{item.system.strain.max}}</span>
            <div class="ptg-print-mini-actions">
              <button type="button" data-item-action="favor">Favor</button>
              <button type="button" data-item-action="devote">Devote</button>
              <button type="button" data-item-action="edit">Edit</button>
              <button type="button" data-item-action="delete">Delete</button>
            </div>
            {{#if item.hasDetails}}
              {{#if item.expanded}}
                <div class="ptg-item-details">
                  {{#each item.sheetDetails as |detail|}}
                    <div><strong>{{detail.label}}</strong> {{{detail.html}}}</div>
                  {{/each}}
                </div>
              {{/if}}
            {{/if}}
          </article>
        {{/each}}
      </div>
    </section>

    <section class="ptg-print-section">
      <div class="ptg-print-section-heading">
        <h2>Worshippers/Vassals</h2>
        {{#if editable}}
          <div class="ptg-print-mini-actions">
            <button type="button" data-item-create="worshipper">Add Worshipper</button>
            <button type="button" data-item-create="vassal">Add Vassal</button>
          </div>
        {{/if}}
      </div>
      <div class="ptg-print-attachment-table followers">
        <div class="ptg-print-attachment-head" title="{{ptgLocalize "PTG.Help.Strain"}}">
          <span>Name</span>
          <span>Type</span>
          <span>Location</span>
          <span>Level</span>
          <span>Strain</span>
          <span></span>
        </div>
        {{#each inventory.worshippers as |item|}}
          <article class="ptg-print-attachment-row" data-item-id="{{item.id}}">
            <span class="ptg-print-attachment-name">
              {{#if item.hasDetails}}
                <button type="button" class="ptg-detail-toggle" data-item-action="toggle-details" aria-expanded="{{item.expanded}}">{{#if item.expanded}}Hide{{else}}Show{{/if}}</button>
              {{else}}
                <span class="ptg-detail-toggle-placeholder" aria-hidden="true"></span>
              {{/if}}
              <strong>{{item.name}}</strong>
            </span>
            <span>Worshipper</span>
            <span>{{item.system.group}}</span>
            <span class="ptg-print-box">{{item.system.level}}</span>
            <span class="ptg-print-box">{{item.system.strain.value}} / {{item.system.strain.max}}</span>
            <div class="ptg-print-mini-actions">
              <button type="button" data-item-action="worshipper-request">Prayer</button>
              <button type="button" data-item-action="use">Use</button>
              <button type="button" data-item-action="edit">Edit</button>
              <button type="button" data-item-action="delete">Delete</button>
            </div>
            {{#if item.hasDetails}}
              {{#if item.expanded}}
                <div class="ptg-item-details">
                  {{#each item.sheetDetails as |detail|}}
                    <div><strong>{{detail.label}}</strong> {{{detail.html}}}</div>
                  {{/each}}
                </div>
              {{/if}}
            {{/if}}
          </article>
        {{/each}}
        {{#each inventory.vassals as |item|}}
          <article class="ptg-print-attachment-row" data-item-id="{{item.id}}">
            <span class="ptg-print-attachment-name">
              {{#if item.hasDetails}}
                <button type="button" class="ptg-detail-toggle" data-item-action="toggle-details" aria-expanded="{{item.expanded}}">{{#if item.expanded}}Hide{{else}}Show{{/if}}</button>
              {{else}}
                <span class="ptg-detail-toggle-placeholder" aria-hidden="true"></span>
              {{/if}}
              <strong>{{item.name}}</strong>
            </span>
            <span>Vassal</span>
            <span>{{item.system.concept}}</span>
            <span class="ptg-print-box">{{item.system.level}}</span>
            <span class="ptg-print-box">{{item.system.strain.value}} / {{item.system.strain.max}}</span>
            <div class="ptg-print-mini-actions">
              <button type="button" data-item-action="vassal-task">Task</button>
              <button type="button" data-item-action="edit">Edit</button>
              <button type="button" data-item-action="delete">Delete</button>
            </div>
            {{#if item.hasDetails}}
              {{#if item.expanded}}
                <div class="ptg-item-details">
                  {{#each item.sheetDetails as |detail|}}
                    <div><strong>{{detail.label}}</strong> {{{detail.html}}}</div>
                  {{/each}}
                </div>
              {{/if}}
            {{/if}}
          </article>
        {{/each}}
      </div>
    </section>

    <section class="ptg-print-back-bottom">
      <section class="ptg-print-section" data-item-drop-type="relic">
        <div class="ptg-print-section-heading">
          <h2>Relics</h2>
          {{#if editable}}<button type="button" data-item-create="relic">Add</button>{{/if}}
        </div>
        <div class="ptg-print-ability-list">
          {{#each inventory.relics as |item|}}
            <article class="ptg-print-ability" data-item-id="{{item.id}}">
              <header>
                <strong>{{item.name}}</strong>
                <span>Level {{item.system.level}}</span>
                {{#if item.hasDetails}}
                  <button type="button" data-item-action="toggle-details" aria-expanded="{{item.expanded}}">{{#if item.expanded}}Hide{{else}}Details{{/if}}</button>
                {{/if}}
                <button type="button" data-item-action="use">Use</button>
                <button type="button" data-item-action="edit">Edit</button>
                <button type="button" data-item-action="delete">Delete</button>
              </header>
              {{#if item.hasDetails}}
                {{#if item.expanded}}
                  <div class="ptg-item-details">
                    {{#each item.sheetDetails as |detail|}}
                      <div><strong>{{detail.label}}</strong> {{{detail.html}}}</div>
                    {{/each}}
                  </div>
                {{/if}}
              {{/if}}
            </article>
          {{/each}}
        </div>
      </section>

      <section class="ptg-print-section" data-item-drop-type="truth">
        <div class="ptg-print-section-heading">
          <h2>Truths</h2>
          {{#if editable}}<button type="button" data-item-create="truth">Add</button>{{/if}}
        </div>
        <div class="ptg-print-truth-list">
          {{#each inventory.truths as |item|}}
            <article class="ptg-print-truth" data-item-id="{{item.id}}">
              <header>
                <strong>"{{item.name}}"</strong>
                <span>Rank {{item.system.rank}}</span>
              </header>
              <div class="ptg-print-mini-actions">
                {{#if item.hasDetails}}
                  <button type="button" data-item-action="toggle-details" aria-expanded="{{item.expanded}}">{{#if item.expanded}}Hide{{else}}Details{{/if}}</button>
                {{/if}}
                <button type="button" data-item-action="use">Use</button>
                <button type="button" data-item-action="edit">Edit</button>
                <button type="button" data-item-action="delete">Delete</button>
              </div>
              {{#if item.hasDetails}}
                {{#if item.expanded}}
                  <div class="ptg-item-details">
                    {{#each item.sheetDetails as |detail|}}
                      <div><strong>{{detail.label}}</strong> {{{detail.html}}}</div>
                    {{/each}}
                  </div>
                {{/if}}
              {{/if}}
            </article>
          {{/each}}
        </div>
      </section>
    </section>

    <section class="ptg-print-section">
      <div class="ptg-print-section-heading">
        <h2>Gear and Notes</h2>
      </div>
      <div class="ptg-inventory-summary">
        <span>Total Cost {{gearSummary.cost}}</span>
        <span>Total Wt {{gearSummary.weight}}</span>
        <span>Equipped Armor {{gearSummary.equippedArmor}}</span>
      </div>
      {{> "systems/part-time-gods/templates/actor/parts/item-list.hbs" items=inventory.gear mode="gear"}}
      <div class="ptg-editor-section">
        {{editor system.notes target="system.notes" button=true editable=editable engine="prosemirror"}}
      </div>
    </section>
  </section>
</form>
