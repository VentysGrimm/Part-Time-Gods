<form class="ptg-sheet" autocomplete="off">
  <header class="ptg-header">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}">
    <div class="ptg-title">
      <input class="ptg-name" name="name" type="text" value="{{actor.name}}" placeholder="Name">
      <input name="system.identity.concept" type="text" value="{{system.identity.concept}}" placeholder="Concept">
    </div>
  </header>

  <section class="ptg-grid ptg-identity">
    <label>
      <span>Occupation</span>
      <input name="system.identity.occupation" type="text" value="{{system.identity.occupation}}">
    </label>
    <label>
      <span>Archetype</span>
      <input name="system.identity.archetype" type="text" value="{{system.identity.archetype}}">
    </label>
    <label>
      <span>Dominion</span>
      <input name="system.identity.dominion" type="text" value="{{system.identity.dominion}}">
    </label>
    <label>
      <span>Theology</span>
      <input name="system.identity.theology" type="text" value="{{system.identity.theology}}">
    </label>
  </section>

  <section class="ptg-resources">
    <label>
      <span>Health</span>
      <div class="ptg-pair">
        <input name="system.resources.health.value" type="number" value="{{system.resources.health.value}}" min="0">
        <strong>/ {{system.resources.health.max}}</strong>
      </div>
    </label>
    <label>
      <span>Psyche</span>
      <div class="ptg-pair">
        <input name="system.resources.psyche.value" type="number" value="{{system.resources.psyche.value}}" min="0">
        <strong>/ {{system.resources.psyche.max}}</strong>
      </div>
    </label>
    <label>
      <span>Fragments</span>
      <input name="system.resources.fragments.value" type="number" value="{{system.resources.fragments.value}}" min="0">
    </label>
    <label>
      <span>Pantheon</span>
      <input name="system.resources.pantheon.value" type="number" value="{{system.resources.pantheon.value}}" min="0">
    </label>
    <label>
      <span>Spark</span>
      <input name="system.resources.spark" type="number" value="{{system.resources.spark}}" min="1">
    </label>
    <label>
      <span>Free Time</span>
      <input name="system.resources.freeTime" type="number" value="{{system.resources.freeTime}}" min="0">
    </label>
    <label>
      <span>Wealth</span>
      <input name="system.resources.wealth" type="number" value="{{system.resources.wealth}}" min="0">
    </label>
  </section>

  <section class="ptg-derived">
    <div><span>Initiative</span><strong>{{system.derived.initiative}}</strong></div>
    <div><span>Strength</span><strong>{{system.derived.strength}}</strong></div>
    <div><span>Movement</span><strong>{{system.derived.movement}}</strong></div>
    <div><span>Armor</span><strong>{{system.derived.armor}}</strong></div>
    <div><span>Carry Wt</span><strong>{{system.derived.carriedWeight}}</strong></div>
  </section>

  <nav class="ptg-tabs">
    <button type="button" class="active" data-ptg-tab="skills">Skills</button>
    <button type="button" data-ptg-tab="manifestations">Manifestations</button>
    <button type="button" data-ptg-tab="inventory">Inventory</button>
    <button type="button" data-ptg-tab="notes">Notes</button>
  </nav>

  <section class="ptg-roll-controls">
    <label>
      <span>Second Skill</span>
      <select data-roll-secondary>
        {{#each skills as |label key|}}
          <option value="{{key}}">{{label}}</option>
        {{/each}}
      </select>
    </label>
    <label>
      <span>Manifest Skill</span>
      <select data-roll-manifestation-skill>
        {{#each skills as |label key|}}
          <option value="{{key}}" {{#if (eq key "discipline")}}selected{{/if}}>{{label}}</option>
        {{/each}}
      </select>
    </label>
    <label>
      <span>Difficulty</span>
      <select data-roll-difficulty>
        {{#each difficulties as |value key|}}
          <option value="{{value}}">{{ptgLabel "difficulties" key}} ({{value}})</option>
        {{/each}}
      </select>
    </label>
  </section>

  <section data-ptg-panel="skills">
    <div class="ptg-list">
      {{#each system.skills as |value key|}}
        <label class="ptg-row">
          <span>{{ptgLabel "skills" key}}</span>
          <input name="system.skills.{{key}}" type="number" value="{{value}}" min="0">
          <button type="button" data-roll-skill="{{key}}">Roll</button>
        </label>
      {{/each}}
    </div>
  </section>

  <section data-ptg-panel="manifestations" hidden>
    <div class="ptg-list">
      {{#each system.manifestations as |value key|}}
        <label class="ptg-row">
          <span>{{ptgLabel "manifestations" key}}</span>
          <input name="system.manifestations.{{key}}" type="number" value="{{value}}" min="0">
          <button type="button" data-roll-manifestation="{{key}}">Invoke</button>
        </label>
      {{/each}}
    </div>
  </section>

  <section data-ptg-panel="inventory" hidden>
    <div class="ptg-inventory">
      <section class="ptg-inventory-group">
        <h2>Character Creation</h2>
        {{> "systems/part-time-gods/templates/actor/parts/item-list.hbs" items=inventory.choices mode="choice"}}
      </section>

      {{#each inventorySections as |section|}}
        <section class="ptg-inventory-group" data-item-section="{{section.key}}">
          <div class="ptg-section-heading">
            <h2>{{section.title}}</h2>
            <span>{{section.family}}</span>
          </div>
          {{> "systems/part-time-gods/templates/actor/parts/item-list.hbs" items=section.items mode=section.mode}}
        </section>
      {{/each}}

      <section class="ptg-inventory-group">
        <h2>Gear</h2>
        <div class="ptg-inventory-summary">
          <span>Total Cost {{gearSummary.cost}}</span>
          <span>Total Wt {{gearSummary.weight}}</span>
          <span>Equipped Armor {{gearSummary.equippedArmor}}</span>
        </div>
        {{> "systems/part-time-gods/templates/actor/parts/item-list.hbs" items=inventory.gear mode="gear"}}
      </section>
    </div>
  </section>

  <section data-ptg-panel="notes" hidden>
    {{editor system.notes target="system.notes" button=true editable=editable engine="prosemirror"}}
  </section>
</form>
